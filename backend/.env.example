# ============================================================
# PropAgent.AI — Environment Variables
# ============================================================

# ── Node.js Express backend ─────────────────────────────────
NODE_ENV=development
PORT=5000

# ── AI Providers ────────────────────────────────────────────
# Existing Anthropic key (keep if you still use it)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (RAG + embeddings)
OPENAI_API_KEY=sk-proj-your-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Database ────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Direct Postgres connection (pgvector)
POSTGRES_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# MongoDB (chat sessions)
MONGO_URI=mongodb://localhost:27017/propagent

# Redis (queue + caching)
REDIS_URL=redis://localhost:6379

# ── FastAPI AI service ──────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
INTERNAL_API_SECRET=replace_with_random_32_byte_hex_string

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# ── Email notifications ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="PropAgent.AI <your-email@gmail.com>"

# ── Billing ─────────────────────────────────────────────────

# Razorpay (India payments)
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe (global payments)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── File storage ────────────────────────────────────────────
STORAGE_BUCKET=propagent-docs
MAX_FILE_SIZE_MB=50

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100